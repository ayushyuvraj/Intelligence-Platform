# RegRadar Environment Configuration
# Copy this file to .env and update with your values

# ============ ENVIRONMENT ============
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ============ DATABASE ============
# Development (SQLite)
DATABASE_URL=sqlite:///./regradar.db

# Production (PostgreSQL) - Uncomment for production
# DATABASE_URL=postgresql://username:password@localhost:5432/regradar

# ============ API CONFIGURATION ============
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ============ EXTERNAL APIs ============
# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# ============ SECURITY ============
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============ MONITORING & LOGGING ============
# Sentry Error Tracking
SENTRY_DSN=

# ============ SCRAPER CONFIGURATION ============
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_HOURS=6
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT_SECONDS=60

# ============ EMAIL CONFIGURATION (Phase 2) ============
# SMTP Server
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_ADDRESS=noreply@regradar.io

# ============ REDIS CACHE (Optional) ============
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=3600

# ============ RATE LIMITING ============
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# ============ AI ENGINE ============
# Model configuration
AI_MODEL=gemini-2.0-flash
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=1000

# ============ ADVANCED SETTINGS ============
# Database connection pooling
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Request timeout
REQUEST_TIMEOUT_SECONDS=30

# Worker configuration
WORKER_THREADS=4
